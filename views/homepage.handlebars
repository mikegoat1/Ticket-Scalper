<section class="search-hero">
  <div class="search-hero__media" aria-hidden="true">
    <img src="/images/Ticket-scalper-desktop-image.jpg" alt="" />
  </div>
  <div class="container search-hero__content">
    <div class="search-hero__copy">
      <h1>Find events worth saving.</h1>
      <p>Search Ticketmaster events by city, category, date, and budget, then save the best matches to your profile.</p>
    </div>

    <form class="search-panel" id="event-search-form">
      <div class="search-panel__primary">
        <label class="search-field search-field--wide" for="event-search-input">
          <span>Event or artist</span>
          <input type="text" id="event-search-input" placeholder="Ariana Grande, Lakers, Hamilton" />
        </label>
        <label class="search-field" for="event-city-input">
          <span>City</span>
          <input type="text" id="event-city-input" placeholder="Los Angeles" />
        </label>
        <button class="btn-search" id="event-search-submit" type="submit">Search</button>
      </div>

      <div class="search-panel__filters">
        <label class="search-field" for="event-category-input">
          <span>Category</span>
          <select id="event-category-input">
            <option value="">Any category</option>
            <option value="music">Music</option>
            <option value="sports">Sports</option>
            <option value="theatre">Theater</option>
            <option value="comedy">Comedy</option>
            <option value="family">Family</option>
          </select>
        </label>
        <label class="search-field" for="event-start-date-input">
          <span>From</span>
          <input type="date" id="event-start-date-input" />
        </label>
        <label class="search-field" for="event-end-date-input">
          <span>To</span>
          <input type="date" id="event-end-date-input" />
        </label>
        <label class="search-field" for="event-max-price-input">
          <span>Max price</span>
          <input type="number" id="event-max-price-input" min="0" step="1" placeholder="250" />
        </label>
        <label class="search-field" for="event-sort-input">
          <span>Sort</span>
          <select id="event-sort-input">
            <option value="relevance,desc">Relevance</option>
            <option value="date,asc">Soonest</option>
            <option value="date,desc">Latest</option>
            <option value="name,asc">Name A-Z</option>
          </select>
        </label>
      </div>
    </form>
  </div>
</section>

<main class="container results-shell">
  <div class="results-toolbar">
    <div>
      <h2>Event matches</h2>
      <p id="result-summary">Loading recommended events...</p>
    </div>
    {{#if logged_in}}
      <a class="profile-link" href="/profile">View saved events</a>
    {{else}}
      <a class="profile-link" href="/login">Sign in to save events</a>
    {{/if}}
  </div>

  <div class="empty-state" id="empty-state" hidden>
    <h3>No events found</h3>
    <p>Try widening the date range, removing the price cap, or searching a nearby city.</p>
  </div>

  <div class="cardContainer" id="concerts"></div>
</main>

<footer class="footContainer">
  <div class="footer-inner">
    <span>Ticket Scalper</span>
    <span>Built with Express, Handlebars, Sequelize, MySQL, and third-party ticket APIs.</span>
  </div>
</footer>
