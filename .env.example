# Database (local dev)
DB_NAME=event_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# Database (Heroku / JawsDB — overrides DB_* above when set)
JAWSDB_URL=

# Session
SESSION_SECRET=generate_a_random_64_char_hex_string

# Third-party API keys (server-side only — never put these in client JS)
SEATGEEK_CLIENT_ID=your_seatgeek_client_id
TICKETMASTER_API_KEY=your_ticketmaster_api_key

# Server
PORT=3001
NODE_ENV=development
